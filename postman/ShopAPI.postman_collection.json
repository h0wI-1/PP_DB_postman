        "name": "Shop API",
        "description": "Коллекция запросов для лабораторной работы 4.\nИнтернет-магазин техники. PostgreSQL + PostgREST.\nБазовый URL задан в environment: {{base_url}}.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "auth": {
        "type": "bearer",
        "bearer": [
            { "key": "token", "value": "{{token}}", "type": "string" }
        ]
    },
    "event": [
        {
            "listen": "prerequest",
            "script": {
                "type": "text/javascript",
                "exec": [""]
            }
        }
