        {
            "name": "04. CRUD",
            "item": [
                {
                    "name": "POST /clients — добавить клиента",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Prefer",       "value": "return=representation" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"name\":  \"Test User\",\n    \"email\": \"test.user@example.com\",\n    \"phone\": \"+7-900-000-00-00\",\n    \"city\":  \"Тестоград\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/clients",
                            "host": ["{{base_url}}"],
                            "path": ["clients"]
                        },
                        "description": "Добавление записи. Prefer: return=representation заставляет PostgREST вернуть созданную строку."
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                                    "const body = pm.response.json();",
                                    "pm.test('Возвращён объект с id', function () {",
                                    "    pm.expect(body[0]).to.have.property('id');",
                                    "});",
                                    "pm.test('name сохранился', function () {",
                                    "    pm.expect(body[0].name).to.eql('Test User');",
                                    "});",
                                    "pm.environment.set('new_client_id', body[0].id);"
                                ]
                            }
                        }
                    ]
                },
