        {
            "name": "03. GET-запросы с параметрами",
            "item": [
                {
                    "name": "GET /clients?id=eq.1",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/clients?id=eq.1",
                            "host": ["{{base_url}}"],
                            "path": ["clients"],
                            "query": [ { "key": "id", "value": "eq.1" } ]
                        },
                        "description": "Выборка клиента по id. Параметр id=eq.1 в PostgREST эквивалентен WHERE id = 1."
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                                    "const body = pm.response.json();",
                                    "pm.test('Вернулся ровно 1 клиент', function () {",
                                    "    pm.expect(body).to.have.lengthOf(1);",
                                    "});",
                                    "pm.test('id = 1', function () {",
                                    "    pm.expect(body[0].id).to.eql(1);",
                                    "});"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "GET /items?price=gt.40000",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/items?price=gt.40000",
                            "host": ["{{base_url}}"],
                            "path": ["items"],
                            "query": [ { "key": "price", "value": "gt.40000" } ]
                        },
                        "description": "Товары дороже 40 000. price=gt.40000 соответствует WHERE price > 40000."
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                                    "const body = pm.response.json();",
                                    "pm.test('Есть хотя бы один товар дороже 40000', function () {",
                                    "    pm.expect(body.length).to.be.above(0);",
                                    "});",
                                    "pm.test('Все цены > 40000', function () {",
                                    "    body.forEach(function (it) { pm.expect(Number(it.price)).to.be.above(40000); });",
                                    "});"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "GET /items?price=lt.50000&order=price.asc",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/items?price=lt.50000&order=price.asc",
                            "host": ["{{base_url}}"],
                            "path": ["items"],
                            "query": [
                                { "key": "price", "value": "lt.50000" },
                                { "key": "order", "value": "price.asc" }
                            ]
                        },
                        "description": "Составной фильтр: дешевле 50 000, отсортировано по возрастанию цены."
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                                    "const body = pm.response.json();",
                                    "pm.test('Все цены < 50000', function () {",
                                    "    body.forEach(function (it) { pm.expect(Number(it.price)).to.be.below(50000); });",
                                    "});",
                                    "pm.test('Отсортировано по возрастанию', function () {",
                                    "    for (let i = 1; i < body.length; i++) {",
                                    "        pm.expect(Number(body[i].price)).to.be.at.least(Number(body[i-1].price));",
                                    "    }",
                                    "});"
                                ]
                            }
                        }
                    ]
                },
