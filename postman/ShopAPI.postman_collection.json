                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                                    "const body = pm.response.json();",
                                    "pm.test('Есть вложенный клиент и товар', function () {",
                                    "    pm.expect(body[0]).to.have.property('clients');",
                                    "    pm.expect(body[0]).to.have.property('items');",
                                    "    pm.expect(body[0].clients).to.have.property('name');",
                                    "    pm.expect(body[0].items).to.have.property('name');",
                                    "});"
                                ]
                            }
