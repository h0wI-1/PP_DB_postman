    "item": [
        {
            "name": "01. Авторизация",
            "item": [
                {
                    "name": "POST /rpc/login — получить JWT",
                    "request": {
                        "auth": { "type": "noauth" },
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Accept", "value": "application/vnd.pgrst.object+json" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"{{login_email}}\",\n    \"password\": \"{{login_password}}\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/rpc/login",
                            "host": ["{{base_url}}"],
                            "path": ["rpc", "login"]
                        },
                        "description": "Вызов функции login(email, password). Возвращает JSON c полем token.\nТест автоматически кладёт токен в environment-переменную token."
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('Status code = 200', function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "pm.test('Response time < 1000ms', function () {",
                                    "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                                    "});",
                                    "const body = pm.response.json();",
                                    "pm.test('Пришёл непустой token', function () {",
                                    "    pm.expect(body).to.have.property('token');",
                                    "    pm.expect(body.token).to.be.a('string').and.not.empty;",
                                    "});",
                                    "pm.environment.set('token', body.token);"
                                ]
                            }
                        }
                    ]
                }
            ]
        },
